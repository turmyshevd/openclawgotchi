# ===================
# OpenClawGotchi Configuration
# ===================
# Copy this file to .env and fill in your values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed Telegram User IDs (comma-separated)
ALLOWED_USERS=123456789

# Allowed Group IDs (comma-separated, optional)
ALLOWED_GROUPS=-1001234567890

# Group chat ID for heartbeat messages (optional)
GROUP_CHAT_ID=0

# Safe defaults (recommended)
ALLOW_ALL_USERS=0

# ===================
# Bot Identity
# ===================
BOT_NAME=Gotchi
OWNER_NAME=Owner
SIBLING_BOT_NAME=

# ===================
# Bot Behavior
# ===================
BOT_LANGUAGE=en
CLAUDE_TIMEOUT=600
HISTORY_LIMIT=10

# ===================
# LiteLLM (Lite mode)
# ===================
DEFAULT_LITE_PRESET=glm

# If DEFAULT_LITE_PRESET=gemini:
# GEMINI_API_KEY=your_key_from_aistudio.google.com
# GEMINI_MODEL=gemini/gemini-2.0-flash

# If DEFAULT_LITE_PRESET=glm (Z.ai): 
# ANTHROPIC_API_KEY=your_zai_api_key_here
# Recommended model for GLM: anthropic/glm-5.1

# Optional: custom API base URL
# GEMINI_API_BASE=

# Active skills (comma-separated)
# Example: weather, discord, devto, obsidian-pro
ACTIVE_SKILLS=weather,obsidian-pro

# Enable LiteLLM tool calls (execute_bash, write_file, etc.)
ENABLE_LITELLM_TOOLS=1

# ===================
# Optional: External RAG (Retrieval-Augmented Generation) service
# ===================
# REST and MCP-SSE transports run independently — set one, the other,
# or both. Typical rag-core deployment: REST on :8765, MCP-SSE on :8766.
# Empty → all RAG tools degrade gracefully (no-op).
# RAG_REST_URL=http://your-rag-host:8765
# RAG_MCP_URL=http://your-rag-host:8766
# RAG_API_KEY=your_rag_bearer_token
# RAG_DEFAULT_COLLECTIONS=agent_notes
#
# Legacy single-URL config still honored (compat shim in config.py):
# RAG_API_URL=http://your-rag-host:8765
# RAG_TRANSPORT=rest    # or "mcp"

# ===================
# OpenAI (Whisper)
# ===================
# REQUIRED for voice message transcription support
OPENAI_API_KEY=your_openai_api_key_here

# ===================
# Optional: Discord Integration
# ===================
# Webhook (easy, send-only)
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/xxx/yyy

# Full bot (advanced)
# DISCORD_BOT_TOKEN=your_bot_token
# DISCORD_CHANNEL_ID=123456789
