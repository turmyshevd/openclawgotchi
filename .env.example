# ===================
# OpenClawGotchi Configuration
# ===================
# Copy this file to .env and fill in your values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed Telegram User IDs (comma-separated)
ALLOWED_USERS=123456789

# Allowed Group IDs (comma-separated, optional)
ALLOWED_GROUPS=-1001234567890

# Group chat ID for heartbeat messages (optional)
GROUP_CHAT_ID=0

# Safe defaults (recommended)
ALLOW_ALL_USERS=0

# ===================
# Bot Identity
# ===================
BOT_NAME=Gotchi
OWNER_NAME=Owner
SIBLING_BOT_NAME=

# ===================
# Bot Behavior
# ===================
BOT_LANGUAGE=en
CLAUDE_TIMEOUT=600
HISTORY_LIMIT=10

# ===================
# LiteLLM (Lite mode)
# ===================
DEFAULT_LITE_PRESET=glm

# If DEFAULT_LITE_PRESET=gemini:
# GEMINI_API_KEY=your_key_from_aistudio.google.com
# GEMINI_MODEL=gemini/gemini-2.0-flash

# If DEFAULT_LITE_PRESET=glm (Z.ai): 
# ANTHROPIC_API_KEY=your_zai_api_key_here
# Recommended model for GLM: anthropic/glm-5.1

# Optional: custom API base URL
# GEMINI_API_BASE=

# Active skills (comma-separated)
# Example: weather, discord, devto, obsidian-pro
ACTIVE_SKILLS=weather,obsidian-pro

# Enable LiteLLM tool calls (execute_bash, write_file, etc.)
ENABLE_LITELLM_TOOLS=1

# ===================
# OpenAI (Whisper + Vision)
# ===================
# REQUIRED for voice transcription and image analysis support
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_VISION_MAX_IMAGE_MB=15

# Optional: UPS HAT (C) battery monitor
# OCG_UPS_ADDR=0x43
# OCG_UPS_BUS=1

# Optional: Syncthing vault rescan for /syncvault
# SYNCTHING_API_URL=http://127.0.0.1:8384/rest/db/scan
# SYNCTHING_API_KEY=your_syncthing_api_key_here

# ===================
# Optional: Discord Integration
# ===================
# Webhook (easy, send-only)
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/xxx/yyy

# Full bot (advanced)
# DISCORD_BOT_TOKEN=your_bot_token
# DISCORD_ALLOWED_CHANNELS=123456789
# DISCORD_ALLOWED_USERS=
# DISCORD_RESPOND_TO_ALL=0
# DISCORD_MAX_ATTACHMENT_MB=15
